---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Badge from '@/components/ui/Badge.astro';
import SectionHeading from '@/components/ui/SectionHeading.astro';
import { SITE } from '@/data/site';

const skills = [
  { category: 'Frontend', items: ['React', 'Vue', 'TypeScript', 'Astro', 'Next.js', 'Nuxt.js', 'Tailwind CSS', 'Vite'] },
  { category: 'Backend', items: ['Node.js', 'Express', 'PostgreSQL', 'GraphQL', 'REST APIs', 'Prisma', 'Go', 'Kubernetes', 'gRPC', 'Java', 'Kotlin', 'Spring Boot', 'Hono'] },
  {category: 'Infrastructure', items: ['Kubernetes', 'Docker', 'Terraform', 'Google Cloud Platform', 'AWS', 'Azure'] },
  { category: 'Databases', items: ['PostgreSQL', 'MySQL', 'MongoDB', 'Redis', 'Firebase', 'Supabase'] },
  { category: 'Tooling & Other', items: ['Git', 'Docker', 'Linux','Kafka', 'Figma', 'CI/CD', 'Testing'] },
];
---

<BaseLayout
  title={`About — ${SITE.name}`}
  description="A bit about Julian Grande — software developer and consultant at Bekk, previously at NTNU."
>
  <div class="mx-auto max-w-5xl px-4 py-16 sm:px-6 sm:py-24">
    <!-- Two-column layout -->
    <div class="grid gap-12 lg:grid-cols-5 lg:gap-16">
      <!-- Left: avatar + quick facts -->
      <div class="lg:col-span-2">
        <!-- Avatar placeholder -->
        <div
          class="mb-6 flex h-40 w-40 items-center justify-center overflow-hidden rounded-2xl border border-slate-200 bg-gradient-to-br from-accent-100 to-accent-50 dark:border-slate-800 dark:from-accent-950/60 dark:to-accent-900/40"
          aria-label="Photo of Julian Grande (placeholder)"
        >
          <span class="text-5xl font-extrabold text-accent-300 dark:text-accent-700" aria-hidden="true">
            JG
          </span>
        </div>

        <h1 class="text-2xl font-bold text-slate-900 dark:text-slate-50">{SITE.name}</h1>
        <p class="mt-1 text-slate-500 dark:text-slate-400">Software Developer</p>

        <!-- Quick links -->
        <div class="mt-5 flex flex-col gap-2">
          {
            SITE.social.github && (
              <a
                href={SITE.social.github}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-2 text-sm text-slate-600 transition-colors hover:text-slate-900 dark:text-slate-400 dark:hover:text-slate-100"
              >
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                  <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z" />
                </svg>
                juliangra
              </a>
            )
          }
          {
            SITE.social.linkedin && (
              <a
                href={SITE.social.linkedin}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-2 text-sm text-slate-600 transition-colors hover:text-slate-900 dark:text-slate-400 dark:hover:text-slate-100"
              >
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                  <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z" />
                </svg>
                Julian Grande
              </a>
            )
          }
        </div>
      </div>

      <!-- Right: bio + now + skills -->
      <div class="lg:col-span-3">
        <SectionHeading label="About" title="Hi, I'm Julian." />

        <!-- Bio -->
        <div class="prose prose-slate dark:prose-invert max-w-none">
          <p class="text-slate-600 dark:text-slate-400 leading-relaxed">
            I'm a software developer based in Norway, working at
            <a href="https://bekk.no" target="_blank" rel="noopener noreferrer" class="text-accent-500 dark:text-accent-300 hover:underline">Bekk</a>.
            I hold a Master's degree in Computer Science from
            <a href="https://ntnu.no" target="_blank" rel="noopener noreferrer" class="text-accent-500 dark:text-accent-300 hover:underline">NTNU</a>.
          </p>
          <p class="mt-4 text-slate-600 dark:text-slate-400 leading-relaxed">
            I care deeply about the craft of building software — writing code that's fast,
            accessible, and a pleasure to maintain. My main focus is frontend and full-stack web
            development, but I enjoy exploring the full spectrum from system design to UI polish.
          </p>
          <p class="mt-4 text-slate-600 dark:text-slate-400 leading-relaxed">
            Outside of work, you'll find me hacking on side projects, listening to music,
            watching Formula 1, or exploring Oslo. I occasionally write about software and the things
            I'm learning, which you can find on the <a href="/blog" class="text-accent-500 dark:text-accent-300 hover:underline">blog</a>.
          </p>
        </div>

        <!-- Now -->
        <div class="mt-10">
          <h2 class="mb-4 text-lg font-semibold text-slate-900 dark:text-slate-50">Now</h2>
          <ul class="space-y-3" role="list">
            {
              SITE.now.map(({ emoji, label }) => (
                <li class="flex items-start gap-3 text-slate-600 dark:text-slate-400">
                  <span class="mt-0.5 text-lg" aria-hidden="true">{emoji}</span>
                  <span>{label}</span>
                </li>
              ))
            }
          </ul>
        </div>

        <!-- Skills -->
        <div class="mt-10 space-y-6">
          <h2 class="text-lg font-semibold text-slate-900 dark:text-slate-50">Tools & Technologies</h2>
          {
            skills.map(({ category, items }) => (
              <div>
                <p class="mb-2 text-sm font-medium text-slate-500 dark:text-slate-400">{category}</p>
                <div class="flex flex-wrap gap-1.5">
                  {items.map((item) => (
                    <Badge>{item}</Badge>
                  ))}
                </div>
              </div>
            ))
          }
        </div>

        <!-- CTA -->
        <div class="mt-10 flex flex-wrap gap-3">
          <a
            href="/work"
            class="inline-flex items-center gap-1.5 rounded-xl bg-accent-500 px-5 py-2.5 text-sm font-semibold text-white shadow-sm transition-all hover:bg-accent-600"
          >
            View my work experience →
          </a>
          <a
            href="/contact"
            class="inline-flex items-center gap-1.5 rounded-xl border border-slate-300 bg-white px-5 py-2.5 text-sm font-semibold text-slate-700 shadow-sm transition-all hover:bg-slate-50 dark:border-slate-700 dark:bg-slate-900 dark:text-slate-300 dark:hover:bg-slate-800"
          >
            Get in touch
          </a>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>
