---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Hero from '@/components/sections/Hero.astro';
import FeaturedProject from '@/components/sections/FeaturedProject.astro';
import NowSection from '@/components/sections/NowSection.astro';
import BlogCard from '@/components/sections/BlogCard.astro';
import SectionHeading from '@/components/ui/SectionHeading.astro';
import { getCollection } from 'astro:content';
import { getFeaturedProjects } from '@/data/projects';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);

const [featured] = getFeaturedProjects();
---

<BaseLayout>
  <Hero />

  {featured && <FeaturedProject project={featured} />}

  <NowSection />

  <!-- Recent blog posts -->
  <section class="border-t border-slate-200 bg-white py-20 sm:py-28 dark:border-slate-800 dark:bg-slate-900/50">
    <div class="mx-auto max-w-5xl px-4 sm:px-6">
      <div class="mb-10 flex items-end justify-between">
        <SectionHeading
          label="Writing"
          title="From the blog."
          description="Thoughts on software, craft, and the web."
        />
        <a
          href="/blog"
          class="hidden shrink-0 text-sm font-medium text-accent-500 transition-colors hover:text-accent-600 dark:text-accent-300 dark:hover:text-accent-200 sm:block"
        >
          All posts →
        </a>
      </div>

      <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {
          posts.map((post) => (
            <BlogCard
              title={post.data.title}
              description={post.data.description}
              date={post.data.date}
              tags={post.data.tags}
              href={`/blog/${post.id.replace(/\.mdx?$/, '')}`}
            />
          ))
        }
      </div>

      <div class="mt-8 sm:hidden">
        <a
          href="/blog"
          class="text-sm font-medium text-accent-500 transition-colors hover:text-accent-600 dark:text-accent-300 dark:hover:text-accent-200"
        >
          All posts →
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
