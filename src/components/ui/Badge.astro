---
interface Props {
  variant?: 'default' | 'accent' | 'outline';
  class?: string;
}

const { variant = 'default', class: className } = Astro.props;

const variants = {
  default:
    'bg-slate-100 text-slate-600 dark:bg-slate-800 dark:text-slate-300',
  accent:
    'bg-accent-50 text-accent-600 dark:bg-accent-950/60 dark:text-accent-300',
  outline:
    'border border-slate-200 text-slate-600 dark:border-slate-700 dark:text-slate-400',
};
---

<span
  class:list={[
    'inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-medium',
    variants[variant],
    className,
  ]}
>
  <slot />
</span>
