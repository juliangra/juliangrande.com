---
import SectionDoodle from '@/components/illustrations/SectionDoodle.astro';

interface Props {
  label?: string;
  title: string;
  description?: string;
  align?: 'left' | 'center';
}

const { label, title, description, align = 'left' } = Astro.props;
---

<div class:list={['mb-12', align === 'center' && 'text-center']}>
  {
    label && (
      <div class:list={['mb-3 flex items-center gap-2', align === 'center' && 'justify-center']}>
        <p class="text-sm font-semibold uppercase tracking-widest text-accent-500 dark:text-accent-300">
          {label}
        </p>
        <span class="text-accent-400 dark:text-accent-500">
          <SectionDoodle />
        </span>
      </div>
    )
  }
  <h2
    class="text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl dark:text-slate-50"
  >
    {title}
  </h2>
  {
    description && (
      <p
        class:list={[
          'mt-4 text-lg text-slate-600 dark:text-slate-400',
          align === 'center' ? 'mx-auto max-w-2xl' : 'max-w-2xl',
        ]}
      >
        {description}
      </p>
    )
  }
</div>
