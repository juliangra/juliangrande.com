---
import { SITE } from '@/data/site';
import { Icon } from 'astro-icon/components';

const year = new Date().getFullYear();
---

<footer class="border-t border-slate-200 bg-slate-50 dark:border-slate-800 dark:bg-slate-950">
  <div class="mx-auto max-w-5xl px-4 py-10 sm:px-6">
    <div class="flex flex-col items-start justify-between gap-6 sm:flex-row sm:items-center">
      <!-- Left: name + tagline -->
      <div>
        <p class="font-semibold text-slate-900 dark:text-slate-50">{SITE.name}</p>
        <p class="mt-0.5 text-sm text-slate-500 dark:text-slate-400">
          Software developer based in Norway.
        </p>
      </div>

      <!-- Right: nav links -->
      <nav aria-label="Footer navigation">
        <ul class="flex flex-wrap gap-x-6 gap-y-2" role="list">
          {
            SITE.nav.map(({ label, href }) => (
              <li>
                <a
                  href={href}
                  class="text-sm text-slate-500 transition-colors hover:text-slate-900 dark:text-slate-400 dark:hover:text-slate-100"
                >
                  {label}
                </a>
              </li>
            ))
          }
        </ul>
      </nav>
    </div>

    <div
      class="mt-8 flex flex-col items-start justify-between gap-4 border-t border-slate-200 pt-6 sm:flex-row sm:items-center dark:border-slate-800"
    >
      <!-- Social links -->
      <div class="flex items-center gap-4">
        {
          SITE.social.github && (
            <a
              href={SITE.social.github}
              target="_blank"
              rel="noopener noreferrer"
              aria-label="GitHub profile"
              class="text-slate-400 transition-colors hover:text-slate-700 dark:hover:text-slate-200"
            >
              <Icon name="lucide:github" width={18} height={18} aria-hidden="true" />
            </a>
          )
        }
        {
          SITE.social.linkedin && (
            <a
              href={SITE.social.linkedin}
              target="_blank"
              rel="noopener noreferrer"
              aria-label="LinkedIn profile"
              class="text-slate-400 transition-colors hover:text-slate-700 dark:hover:text-slate-200"
            >
              <Icon name="lucide:linkedin" width={18} height={18} aria-hidden="true" />
            </a>
          )
        }
        <a
          href="/rss.xml"
          aria-label="RSS feed"
          class="text-slate-400 transition-colors hover:text-slate-700 dark:hover:text-slate-200"
        >
          <Icon name="lucide:rss" width={18} height={18} aria-hidden="true" />
        </a>
      </div>

      <p class="text-sm text-slate-400 dark:text-slate-500">
        © {year} {SITE.name}. Built with Astro.
      </p>
    </div>
  </div>
</footer>
