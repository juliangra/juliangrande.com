---
import { SITE } from '@/data/site';
import SectionHeading from '@/components/ui/SectionHeading.astro';
import { projects } from '@/data/projects';
import { workEntries } from '@/data/work';

const experience = new Date().getFullYear() - new Date(workEntries.sort((a, b) => new Date(a.startDate).getTime() - new Date(b.startDate).getTime())[0].startDate).getFullYear()

---

<section class="py-20 sm:py-28">
  <div class="mx-auto max-w-5xl px-4 sm:px-6">
    <div class="grid gap-12 lg:grid-cols-2 lg:gap-16">
      <div>
        <SectionHeading
          label="Currently"
          title="What I'm up to now."
          description="A living snapshot of what I'm working on, reading, and thinking about."
        />
        <ul class="space-y-4" role="list">
          {
            SITE.now.map(({ emoji, label }) => (
              <li class="flex items-start gap-3">
                <span class="mt-0.5 text-xl leading-none" aria-hidden="true">
                  {emoji}
                </span>
                <span class="text-slate-600 dark:text-slate-400">{label}</span>
              </li>
            ))
          }
        </ul>
        <div class="mt-8">
          <a
            href="/about"
            class="inline-flex items-center gap-1.5 text-sm font-medium text-indigo-600 transition-colors hover:text-indigo-700 dark:text-indigo-400 dark:hover:text-indigo-300"
          >
            More about me
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="14"
              height="14"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2.5"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <path d="M5 12h14"></path>
              <path d="m12 5 7 7-7 7"></path>
            </svg>
          </a>
        </div>
      </div>

      <!-- Quick stats / highlights -->
      <div class="grid grid-cols-2 content-start gap-4">
        {
          [
            { value: `${experience}+`, label: 'Years of experience', icon: '🗓️' },
            { value: `${projects.length}+`, label: 'Projects shipped', icon: '🚀' },
            { value: '∞', label: 'Cups of coffee', icon: '☕' },
            { value: '2', label: 'Degrees from NTNU', icon: '🎓' },
          ].map(({ value, label, icon }) => (
            <div class="rounded-xl border border-slate-200 bg-white p-5 dark:border-slate-800 dark:bg-slate-900">
              <div class="mb-2 text-2xl" aria-hidden="true">
                {icon}
              </div>
              <div class="text-2xl font-bold text-slate-900 dark:text-slate-50">{value}</div>
              <div class="mt-0.5 text-sm text-slate-500 dark:text-slate-400">{label}</div>
            </div>
          ))
        }
      </div>
    </div>
  </div>
</section>
