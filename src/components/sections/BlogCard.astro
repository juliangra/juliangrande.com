---
import Badge from '@/components/ui/Badge.astro';

interface Props {
  title: string;
  description: string;
  date: Date;
  tags: string[];
  href: string;
}

const { title, description, date, tags, href } = Astro.props;

const formattedDate = date.toLocaleDateString('en-GB', {
  day: 'numeric',
  month: 'short',
  year: 'numeric',
});
---

<article>
  <a
    href={href}
    class="group block rounded-2xl border border-slate-200 bg-white p-6 transition-all duration-200 hover:border-accent-200 hover:shadow-md dark:border-slate-800 dark:bg-slate-900 dark:hover:border-accent-900 dark:hover:shadow-accent-950/20"
  >
    <div class="flex flex-col gap-3">
      <!-- Meta -->
      <div class="flex items-center justify-between">
        <time
          datetime={date.toISOString()}
          class="text-xs font-medium text-slate-400 dark:text-slate-500"
        >
          {formattedDate}
        </time>
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="16"
          height="16"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          class="text-slate-300 transition-transform duration-200 group-hover:translate-x-0.5 group-hover:text-accent-400 dark:text-slate-600"
          aria-hidden="true"
        >
          <path d="M5 12h14"></path>
          <path d="m12 5 7 7-7 7"></path>
        </svg>
      </div>

      <!-- Title -->
      <h3
        class="font-semibold leading-snug text-slate-900 transition-colors group-hover:text-accent-600 dark:text-slate-50 dark:group-hover:text-accent-300"
      >
        {title}
      </h3>

      <!-- Description -->
      <p class="line-clamp-2 text-sm leading-relaxed text-slate-600 dark:text-slate-400">
        {description}
      </p>

      <!-- Tags -->
      {
        tags.length > 0 && (
          <div class="flex flex-wrap gap-1.5 pt-1">
            {tags.slice(0, 3).map((tag) => (
              <Badge>{tag}</Badge>
            ))}
          </div>
        )
      }
    </div>
  </a>
</article>
