---
// Abstract tech illustration for the hero section.
// Thin-stroke geometric shapes in the site's teal palette at low opacity.
// Designed to suggest "building for the web" without being literal.
---

<svg
  viewBox="0 0 420 380"
  fill="none"
  xmlns="http://www.w3.org/2000/svg"
  aria-hidden="true"
  class="w-full max-w-md"
>
  <!-- ── Browser / code editor window ───────────────────────────────── -->
  <rect x="20" y="12" width="248" height="168" rx="12" stroke="#68bebf" stroke-width="1.5" opacity="0.28"/>
  <line x1="20" y1="40" x2="268" y2="40" stroke="#68bebf" stroke-width="1" opacity="0.22"/>
  <!-- Traffic-light dots -->
  <circle cx="40"  cy="26" r="5" fill="#68bebf" opacity="0.22"/>
  <circle cx="56"  cy="26" r="5" fill="#68bebf" opacity="0.16"/>
  <circle cx="72"  cy="26" r="5" fill="#68bebf" opacity="0.10"/>
  <!-- Code line stubs -->
  <rect x="38"  y="56"  width="56"  height="7" rx="3.5" fill="#68bebf" opacity="0.18"/>
  <rect x="38"  y="72"  width="100" height="7" rx="3.5" fill="#68bebf" opacity="0.12"/>
  <rect x="54"  y="88"  width="76"  height="7" rx="3.5" fill="#68bebf" opacity="0.10"/>
  <rect x="54"  y="104" width="60"  height="7" rx="3.5" fill="#68bebf" opacity="0.13"/>
  <rect x="38"  y="120" width="116" height="7" rx="3.5" fill="#68bebf" opacity="0.10"/>
  <rect x="38"  y="136" width="44"  height="7" rx="3.5" fill="#68bebf" opacity="0.16"/>
  <rect x="54"  y="152" width="80"  height="7" rx="3.5" fill="#68bebf" opacity="0.09"/>

  <!-- ── Floating card (bottom-right of window) ─────────────────────── -->
  <rect x="200" y="148" width="168" height="108" rx="10" stroke="#68bebf" stroke-width="1.5" opacity="0.20"/>
  <rect x="216" y="166" width="72"  height="6"  rx="3"  fill="#68bebf" opacity="0.14"/>
  <rect x="216" y="180" width="136" height="6"  rx="3"  fill="#68bebf" opacity="0.10"/>
  <rect x="216" y="194" width="56"  height="6"  rx="3"  fill="#68bebf" opacity="0.13"/>
  <rect x="216" y="208" width="104" height="6"  rx="3"  fill="#68bebf" opacity="0.08"/>
  <rect x="216" y="222" width="36"  height="6"  rx="3"  fill="#68bebf" opacity="0.13"/>
  <!-- Small button stub -->
  <rect x="216" y="236" width="48"  height="14" rx="7"  fill="#68bebf" opacity="0.12"/>

  <!-- ── Floating dots + connections (top-right cluster) ────────────── -->
  <circle cx="322" cy="52"  r="5" fill="#68bebf" opacity="0.20"/>
  <circle cx="358" cy="88"  r="4" fill="#68bebf" opacity="0.14"/>
  <circle cx="390" cy="44"  r="6" fill="#68bebf" opacity="0.11"/>
  <circle cx="374" cy="20"  r="3" fill="#68bebf" opacity="0.18"/>
  <circle cx="408" cy="76"  r="3" fill="#68bebf" opacity="0.13"/>
  <!-- Dashed connector lines -->
  <line x1="322" y1="52"  x2="358" y2="88"  stroke="#68bebf" stroke-width="1" stroke-dasharray="3 5" opacity="0.15"/>
  <line x1="322" y1="52"  x2="390" y2="44"  stroke="#68bebf" stroke-width="1" stroke-dasharray="3 5" opacity="0.12"/>
  <line x1="390" y1="44"  x2="374" y2="20"  stroke="#68bebf" stroke-width="1" stroke-dasharray="3 5" opacity="0.12"/>
  <line x1="358" y1="88"  x2="408" y2="76"  stroke="#68bebf" stroke-width="1" stroke-dasharray="3 5" opacity="0.10"/>

  <!-- ── Bottom-left card (component/widget) ────────────────────────── -->
  <rect x="14"  y="212" width="126" height="88" rx="10" stroke="#68bebf" stroke-width="1.5" opacity="0.20"/>
  <rect x="28"  y="228" width="52"  height="6"  rx="3"  fill="#68bebf" opacity="0.16"/>
  <rect x="28"  y="242" width="96"  height="6"  rx="3"  fill="#68bebf" opacity="0.10"/>
  <rect x="28"  y="256" width="72"  height="6"  rx="3"  fill="#68bebf" opacity="0.10"/>
  <!-- Mini progress bar -->
  <rect x="28"  y="272" width="96"  height="5"  rx="2.5" fill="#68bebf" opacity="0.08"/>
  <rect x="28"  y="272" width="60"  height="5"  rx="2.5" fill="#68bebf" opacity="0.18"/>

  <!-- ── Pixel/grid cluster (centre-bottom) ────────────────────────── -->
  <rect x="162" y="302" width="13" height="13" rx="2.5" fill="#68bebf" opacity="0.14"/>
  <rect x="181" y="302" width="13" height="13" rx="2.5" fill="#68bebf" opacity="0.09"/>
  <rect x="200" y="302" width="13" height="13" rx="2.5" fill="#68bebf" opacity="0.17"/>
  <rect x="162" y="321" width="13" height="13" rx="2.5" fill="#68bebf" opacity="0.08"/>
  <rect x="181" y="321" width="13" height="13" rx="2.5" fill="#68bebf" opacity="0.16"/>
  <rect x="200" y="321" width="13" height="13" rx="2.5" fill="#68bebf" opacity="0.11"/>
  <rect x="162" y="340" width="13" height="13" rx="2.5" fill="#68bebf" opacity="0.13"/>
  <rect x="181" y="340" width="13" height="13" rx="2.5" fill="#68bebf" opacity="0.10"/>
  <rect x="200" y="340" width="13" height="13" rx="2.5" fill="#68bebf" opacity="0.08"/>

  <!-- ── Concentric dashed rings (bottom-right accent) ─────────────── -->
  <circle cx="364" cy="314" r="54" stroke="#68bebf" stroke-width="1.5" stroke-dasharray="4 7" opacity="0.11"/>
  <circle cx="364" cy="314" r="34" stroke="#68bebf" stroke-width="1"   stroke-dasharray="3 6" opacity="0.08"/>
  <circle cx="364" cy="314" r="12" fill="#68bebf" opacity="0.08"/>

  <!-- ── Scattered accent dots ──────────────────────────────────────── -->
  <circle cx="148" cy="198" r="3" fill="#68bebf" opacity="0.20"/>
  <circle cx="164" cy="210" r="2" fill="#68bebf" opacity="0.14"/>
  <circle cx="136" cy="212" r="2" fill="#68bebf" opacity="0.16"/>
  <circle cx="292" cy="278" r="3" fill="#68bebf" opacity="0.18"/>
  <circle cx="308" cy="268" r="2" fill="#68bebf" opacity="0.12"/>
</svg>
