---
import BaseLayout from './BaseLayout.astro';
import Badge from '@/components/ui/Badge.astro';
import { SITE } from '@/data/site';

interface Props {
  title: string;
  description: string;
  date: Date;
  tags?: string[];
  ogImage?: string;
}

const { title, description, date, tags = [], ogImage } = Astro.props;

const formattedDate = date.toLocaleDateString('en-GB', {
  day: 'numeric',
  month: 'long',
  year: 'numeric',
});

const readingTimeMinutes = '5'; // placeholder — replace with actual reading time util if desired
---

<BaseLayout
  title={`${title} — ${SITE.name}`}
  description={description}
  ogImage={ogImage}
>
  <article class="mx-auto max-w-2xl px-4 py-16 sm:px-6 sm:py-24">
    <!-- Back link -->
    <a
      href="/blog"
      class="mb-8 inline-flex items-center gap-1.5 text-sm text-slate-500 transition-colors hover:text-slate-900 dark:text-slate-400 dark:hover:text-slate-100"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="14"
        height="14"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
      >
        <path d="m15 18-6-6 6-6"></path>
      </svg>
      All posts
    </a>

    <!-- Header -->
    <header class="mb-10">
      <!-- Tags -->
      {
        tags.length > 0 && (
          <div class="mb-4 flex flex-wrap gap-2">
            {tags.map((tag) => (
              <Badge>{tag}</Badge>
            ))}
          </div>
        )
      }

      <h1
        class="text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl dark:text-slate-50"
      >
        {title}
      </h1>

      <p class="mt-3 text-lg text-slate-600 dark:text-slate-400">{description}</p>

      <div class="mt-4 flex items-center gap-4 text-sm text-slate-500 dark:text-slate-400">
        <time datetime={date.toISOString()}>{formattedDate}</time>
        <span aria-hidden="true">·</span>
        <span>{readingTimeMinutes} min read</span>
      </div>
    </header>

    <hr class="border-slate-200 dark:border-slate-800" />

    <!-- Post content -->
    <div
      class="prose prose-slate dark:prose-invert mt-10 max-w-none
        prose-headings:font-bold prose-headings:tracking-tight
        prose-headings:dark:text-white
        prose-a:text-accent-500 prose-a:no-underline hover:prose-a:underline
        dark:text-gray-400
        dark:prose-a:text-accent-300
        prose-code:rounded prose-code:font-normal
        prose-pre:rounded-xl prose-pre:border prose-pre:border-slate-700"
    >
      <slot />
    </div>

    <!-- Footer: share / back -->
    <footer class="mt-16 border-t border-slate-200 pt-8 dark:border-slate-800">
      <div class="flex items-center justify-between">
        <a
          href="/blog"
          class="inline-flex items-center gap-1.5 text-sm font-medium text-accent-500 transition-colors hover:text-accent-600 dark:text-accent-300 dark:hover:text-accent-200"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="14"
            height="14"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <path d="m15 18-6-6 6-6"></path>
          </svg>
          Back to all posts
        </a>

        <a
          href={SITE.social.github}
          target="_blank"
          rel="noopener noreferrer"
          class="text-sm text-slate-500 transition-colors hover:text-slate-700 dark:text-slate-400 dark:hover:text-slate-200"
        >
          View on GitHub
        </a>
      </div>
    </footer>
  </article>
</BaseLayout>
